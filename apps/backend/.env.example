# ==================== 服务器配置 ====================
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000

# ==================== 数据库配置 ====================
DATABASE_URL=postgresql://user:password@localhost:5432/knowledge_base_db?schema=public

# ==================== Redis 配置 ====================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ==================== MinIO 配置 ====================
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=knowledge-base

# ==================== 阿里云 Embedding 配置 ====================
ALIYUN_EMBEDDING_API_KEY=your-api-key-here
ALIYUN_EMBEDDING_ENDPOINT=https://dashscope.aliyuncs.com/api/v1/services/embeddings/text-embedding/generation
ALIYUN_EMBEDDING_MODEL=text-embedding-v2

# ==================== JWT 配置 ====================
JWT_SECRET=your-jwt-secret-key-here
JWT_EXPIRES_IN=7d

# ==================== 日志配置 ====================
LOG_LEVEL=info
LOG_FILE=logs/app.log
